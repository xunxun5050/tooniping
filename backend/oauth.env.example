# Backend OAuth/local auth configuration example
# Copy this file to backend/oauth.env and fill values.

APP_AUTH_USERNAME=admin
APP_AUTH_PASSWORD=admin1234
APP_AUTH_SECRET=change-this-secret
APP_AUTH_TOKEN_VALID_MINUTES=480

# Email verification SMTP
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
APP_AUTH_EMAIL_VERIFICATION_FROM=no-reply@tooniping.app
APP_AUTH_EMAIL_VERIFICATION_EXPIRE_MINUTES=10
APP_AUTH_EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# Frontend base URL for OAuth callback redirect
APP_AUTH_OAUTH_FRONTEND_BASE_URL=http://localhost:3000

# Kakao OAuth (https://developers.kakao.com)
APP_AUTH_OAUTH_KAKAO_CLIENT_ID=
APP_AUTH_OAUTH_KAKAO_CLIENT_SECRET=
APP_AUTH_OAUTH_KAKAO_REDIRECT_URI=http://localhost:8080/api/auth/oauth/kakao/callback

# Naver OAuth (https://developers.naver.com)
APP_AUTH_OAUTH_NAVER_CLIENT_ID=
APP_AUTH_OAUTH_NAVER_CLIENT_SECRET=
APP_AUTH_OAUTH_NAVER_REDIRECT_URI=http://localhost:8080/api/auth/oauth/naver/callback
